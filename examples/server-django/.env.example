# ──────────────────────────────────────────────
# Django Configuration
# ──────────────────────────────────────────────
DEBUG=True                                       # Set False in production
SECRET_KEY=your-django-secret-key-here           # Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ──────────────────────────────────────────────
# Tenxyte Configuration
# ──────────────────────────────────────────────
TENXYTE_JWT_SECRET_KEY=                          # Leave empty for auto-key in dev; REQUIRED in production
TENXYTE_SECURE_MODE=development                  # development | medium | robust
TENXYTE_MAGIC_LINK_BASE_URL=http://localhost:5173  # Frontend URL for magic link redirects

# ──────────────────────────────────────────────
# Database (MongoDB 7)
# ──────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017              # Use mongodb://localhost:27017 for local dev
MONGODB_DB=tenxyte_db                            # Database name

# ──────────────────────────────────────────────
# Redis (Celery broker + result backend)
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0                   # Use redis://localhost:6379/0 for local dev

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
DJANGO_BASE_URL=http://localhost:8000            # Public server URL

# ──────────────────────────────────────────────
# Social OAuth (optional — configure in provider console)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                # Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=                            # Same as above
