# Django Configuration
DEBUG=True
SECRET_KEY=your-django-secret-key-here

# Tenxyte Configuration
# Leave empty for ephemeral auto-key in development; required in production
TENXYTE_JWT_SECRET_KEY=
TENXYTE_SECURE_MODE=development
TENXYTE_MAGIC_LINK_BASE_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=tenxyte_db

# Celery
REDIS_URL=redis://redis:6379/0

# API Base URL
DJANGO_BASE_URL=http://localhost:8000

# Social OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
