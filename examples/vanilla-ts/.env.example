# Tenxyte API base URL
# Default local dev server — change if your backend runs on a different port
VITE_TENXYTE_BASE_URL=http://localhost:8000

# API credentials — find these in your Tenxyte dashboard → Settings → API Keys
VITE_TENXYTE_ACCESS_KEY=your_access_key_here
VITE_TENXYTE_ACCESS_SECRET=your_access_secret_here
