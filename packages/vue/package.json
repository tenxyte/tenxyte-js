{
    "name": "@tenxyte/vue",
    "version": "0.5.2",
    "description": "Vue bindings for the Tenxyte SDK",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "repository": {
        "url": "https://github.com/tenxyte/tenxyte-js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "tenxyte",
        "vue",
        "composables",
        "authentication",
        "rbac",
        "sdk"
    ],
    "author": "Tenxyte Team",
    "license": "MIT",
    "type": "module",
    "peerDependencies": {
        "@tenxyte/core": "^0.9.3",
        "vue": "^3.3.0"
    },
    "devDependencies": {
        "@tenxyte/core": "file:../core",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vue": "^3.5.0"
    }
}
